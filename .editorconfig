# F-077: Cross-IDE formatting standard for Raccoon File Manager
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
indent_size = 4
max_line_length = 120

[*.xml]
indent_size = 4

[*.{gradle,gradle.kts}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{json,yaml,yml}]
indent_size = 2
