<?xml version="1.0" encoding="utf-8"?>
<!-- Badge entrance — scale up from center with fade for a subtle pop-in effect.
     Uses motion_micro (120ms) for snappy feedback appropriate to small UI elements. -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/overshoot_interpolator">

    <scale
        android:fromXScale="0.0"
        android:toXScale="1.0"
        android:fromYScale="0.0"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="@integer/motion_enter" />

    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="@integer/motion_micro" />
</set>
