<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom sheet entrance — slide up from bottom with decelerate, character-appropriate timing -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/fast_out_slow_in_custom">

    <translate
        android:fromYDelta="100%"
        android:toYDelta="0"
        android:duration="@integer/motion_page" />

    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="@integer/motion_enter" />
</set>
