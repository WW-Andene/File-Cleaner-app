<?xml version="1.0" encoding="utf-8"?>
<!-- Hero card press feedback — more dramatic elevation change for primary CTA -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="@integer/motion_micro"
                android:valueTo="0dp"
                android:valueType="floatType" />
        </set>
    </item>
    <item>
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="@integer/motion_micro"
                android:valueTo="4dp"
                android:valueType="floatType" />
        </set>
    </item>
</selector>
