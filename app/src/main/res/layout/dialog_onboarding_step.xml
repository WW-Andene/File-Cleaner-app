<?xml version="1.0" encoding="utf-8"?>
<!-- Onboarding step layout — uses MaterialCardView for proper rounded corners -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_lg"
    android:layout_marginVertical="@dimen/spacing_3xl"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/elevation_raised"
    app:cardBackgroundColor="@color/surfaceElevated"
    app:strokeWidth="@dimen/stroke_default"
    app:strokeColor="@color/borderSubtle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xxl">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_step_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.Headline"
            android:textColor="@color/textPrimary" />

        <!-- Step indicator -->
        <TextView
            android:id="@+id/tv_step_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
            android:textColor="@color/textTertiary"
            android:accessibilityLiveRegion="polite" />

        <!-- Icon -->
        <ImageView
            android:id="@+id/iv_step_icon"
            android:layout_width="@dimen/onboarding_icon_size"
            android:layout_height="@dimen/onboarding_icon_size"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:scaleType="fitCenter" />

        <!-- Body text -->
        <TextView
            android:id="@+id/tv_step_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.Body"
            android:lineSpacingMultiplier="1.4" />

        <!-- Button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="@dimen/spacing_xl">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.FileCleaner.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_skip"
                style="@style/Widget.FileCleaner.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next"
                style="@style/Widget.FileCleaner.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
