<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surfaceBase">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:scaleType="centerInside"
            app:tint="@color/textPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/av_title"
            android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
            android:textColor="@color/textPrimary"
            android:layout_marginStart="@dimen/spacing_sm" />
    </LinearLayout>

    <!-- Scan status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingVertical="@dimen/spacing_md">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/av_ready"
            android:textAppearance="@style/TextAppearance.FileCleaner.Body"
            android:textColor="@color/textPrimary" />

        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:max="100"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_phase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="@dimen/spacing_xs"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Start scan button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scan"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:text="@string/av_start_scan"
        android:textAllCaps="false"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="@dimen/radius_pill" />

    <!-- Summary cards -->
    <LinearLayout
        android:id="@+id/summary_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_xs"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="@dimen/elevation_none"
            app:cardBackgroundColor="@color/surfaceColor"
            app:strokeWidth="@dimen/stroke_default"
            app:strokeColor="@color/borderSubtle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tv_threat_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Title"
                    android:textColor="@color/colorError" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/av_threats"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/textSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            app:cardCornerRadius="@dimen/radius_card"
            app:cardElevation="@dimen/elevation_none"
            app:cardBackgroundColor="@color/surfaceColor"
            app:strokeWidth="@dimen/stroke_default"
            app:strokeColor="@color/borderSubtle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tv_clean_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Title"
                    android:textColor="@color/colorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/av_clean"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
                    android:textColor="@color/textSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Results list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_above_nav"
        android:visibility="gone" />
</LinearLayout>
