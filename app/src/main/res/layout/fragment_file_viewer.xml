<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surfaceBase">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm"
        android:background="@color/surfaceElevated">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/onboarding_back"
            app:tint="@color/textPrimary" />

        <TextView
            android:id="@+id/tv_filename"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:textAppearance="@style/TextAppearance.FileCleaner.Body"
            android:maxLines="1"
            android:ellipsize="middle" />

        <ImageButton
            android:id="@+id/btn_open_external"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_open"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/ctx_open"
            app:tint="@color/textPrimary" />

        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/ctx_share"
            app:tint="@color/textPrimary" />
    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Image viewer (hidden by default) -->
        <ImageView
            android:id="@+id/iv_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <!-- PDF page viewer (hidden by default) -->
        <LinearLayout
            android:id="@+id/pdf_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_pdf_page"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="fitCenter"
                android:background="@android:color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="@dimen/spacing_sm"
                android:background="@color/surfaceElevated">

                <ImageButton
                    android:id="@+id/btn_pdf_prev"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/onboarding_back"
                    app:tint="@color/textPrimary" />

                <TextView
                    android:id="@+id/tv_pdf_page_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_lg"
                    android:textAppearance="@style/TextAppearance.FileCleaner.Body" />

                <ImageButton
                    android:id="@+id/btn_pdf_next"
                    android:layout_width="@dimen/icon_button"
                    android:layout_height="@dimen/icon_button"
                    android:src="@drawable/ic_arrow_forward"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/onboarding_next"
                    app:tint="@color/textPrimary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Text viewer (hidden by default) -->
        <ScrollView
            android:id="@+id/scroll_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_text_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_lg"
                android:fontFamily="monospace"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:textIsSelectable="true" />
        </ScrollView>

        <!-- Unsupported type fallback -->
        <LinearLayout
            android:id="@+id/unsupported_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_unsupported"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.FileCleaner.Body"
                android:textColor="@color/textSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_fallback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/ctx_open" />
        </LinearLayout>
    </FrameLayout>

    <!-- File info bar -->
    <TextView
        android:id="@+id/tv_file_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.FileCleaner.Caption"
        android:textColor="@color/textTertiary"
        android:gravity="center"
        android:background="@color/surfaceElevated" />

</LinearLayout>
