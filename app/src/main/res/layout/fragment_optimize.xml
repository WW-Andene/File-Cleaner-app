<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surfaceBase">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingVertical="@dimen/spacing_sm">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/icon_button"
            android:layout_height="@dimen/icon_button"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            app:tint="@color/textPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/optimize_title"
            android:textAppearance="@style/TextAppearance.FileCleaner.Title" />
    </LinearLayout>

    <!-- Explanatory card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_sm"
        app:cardCornerRadius="@dimen/radius_header"
        app:cardElevation="@dimen/elevation_none"
        app:cardBackgroundColor="@color/colorPrimaryContainer"
        app:strokeWidth="@dimen/stroke_none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/optimize_info_title"
                android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
                android:textColor="@color/colorOnPrimaryContainer"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/optimize_info_body"
                android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
                android:textColor="@color/colorOnPrimaryContainer"
                android:alpha="0.85" />

            <!-- Select All / Deselect All -->
            <LinearLayout
                android:id="@+id/selection_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_all"
                    style="@style/Widget.FileCleaner.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_sm"
                    android:text="@string/select_all"
                    android:textSize="@dimen/text_body_small"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="@color/colorOnPrimaryContainer"
                    android:textColor="@color/colorOnPrimaryContainer"
                    app:cornerRadius="@dimen/radius_pill" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_deselect_all"
                    style="@style/Widget.FileCleaner.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_sm"
                    android:text="@string/deselect_all"
                    android:textSize="@dimen/text_body_small"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="@color/colorOnPrimaryContainer"
                    android:textColor="@color/colorOnPrimaryContainer"
                    app:cornerRadius="@dimen/radius_pill" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Summary -->
    <TextView
        android:id="@+id/tv_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingVertical="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.FileCleaner.Body"
        android:textColor="@color/textSecondary" />

    <!-- Suggestions list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_suggestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_lg" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/optimize_empty"
        android:textAppearance="@style/TextAppearance.FileCleaner.Body"
        android:textColor="@color/textSecondary"
        android:visibility="gone" />

    <!-- Apply button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/button_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_bottom_inset"
        android:minWidth="@dimen/button_min_width"
        android:paddingHorizontal="@dimen/spacing_3xl"
        android:text="@string/optimize_apply"
        android:textAllCaps="false"
        android:textAppearance="@style/TextAppearance.FileCleaner.Body"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="@dimen/radius_btn" />

</LinearLayout>
