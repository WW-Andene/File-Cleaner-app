<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable loading/scanning state — branded circular progress with message -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_3xl"
    android:visibility="gone">

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progress_loading"
        style="@style/Widget.FileCleaner.CircularProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        app:indicatorSize="56dp" />

    <TextView
        android:id="@+id/tv_loading_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:textAppearance="@style/TextAppearance.FileCleaner.Subtitle"
        android:textColor="@color/textPrimary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tv_loading_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.FileCleaner.BodySmall"
        android:textColor="@color/textTertiary"
        android:gravity="center" />
</LinearLayout>
