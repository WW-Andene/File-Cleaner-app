<?xml version="1.0" encoding="utf-8"?>
<!-- Shared element transition — for list-item-to-detail screen transitions -->
<transitionSet xmlns:android="http://schemas.android.com/apk/res/android"
    android:transitionOrdering="together"
    android:duration="@integer/motion_page"
    android:interpolator="@interpolator/fast_out_slow_in_custom">

    <changeBounds />

    <changeTransform />

    <changeClipBounds />

    <changeImageTransform />
</transitionSet>
